DATABRICKS_HOST=""
DATABRICKS_TOKEN=""
CATALOG="med_atlas_ai"
SCHEMA="default"
LLM_ENDPOINT="databricks-meta-llama-3-3-70b-instruct"
EMBEDDING_ENDPOINT="qwen3-embedding-0-6b"
VS_ENDPOINT_NAME="med_atlas_vs_endpoint"
CSV_PATH="Virtue Foundation Ghana v0.3 - Sheet1.csv"
# Databricks Connect — set ONE of these:
#   DATABRICKS_CLUSTER_ID=your-cluster-id    (for interactive cluster)
#   DATABRICKS_SERVERLESS=true               (for serverless compute)
DATABRICKS_SERVERLESS="true"
# Parallel processing — increase to 16 if the LLM endpoint allows higher throughput
MAX_WORKERS=6
MAX_PROCESS_ROWS=50